@inject SiteContent Site
<!DOCTYPE html>
<html lang="de" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? Site.BrandName)</title>
    <meta name="description" content="@Site.BrandName – @Site.Tagline" />
    <meta name="theme-color" content="#0b1416" />
    <meta property="og:title" content="@Site.BrandName" />
    <meta property="og:description" content="@Site.Tagline" />
    <meta property="og:type" content="website" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // Apply the persisted (or system) theme before first paint to avoid a flash.
        (function () {
            try {
                var stored = localStorage.getItem("matthix-theme");
                var prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
                var theme = stored || (prefersLight ? "light" : "dark");
                document.documentElement.setAttribute("data-theme", theme);
            } catch (e) { /* keep default */ }
        })();
    </script>
</head>
<body>
    <canvas id="network-canvas" class="network-canvas" aria-hidden="true"></canvas>

    <a class="skip-link" href="#main">Zum Inhalt springen</a>

    <header class="masthead" id="masthead">
        <div class="masthead-inner">
            <a class="brand" href="/" aria-label="@Site.BrandName Startseite">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 220 170" role="img">
                        <path d="M35 145 C18 126, 31 74, 64 28 C79 8, 100 11, 97 42 C94 79, 84 117, 96 124 C109 132, 132 89, 172 41 C193 15, 210 8, 203 43 C195 83, 182 126, 166 162"></path>
                    </svg>
                </span>
                <span class="brand-text">@Site.BrandName</span>
            </a>

            <nav class="site-nav" aria-label="Hauptnavigation">
                @foreach (var item in Site.Navigation)
                {
                    <a data-nav-link href="@item.Href">@item.Label</a>
                }
            </nav>

            <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Farbschema wechseln">
                <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
                </svg>
                <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
                </svg>
            </button>
        </div>
    </header>

    <main id="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <span class="footer-brand">@Site.BrandName</span>
            <span class="footer-meta">© @DateTime.UtcNow.Year — @Site.Tagline</span>
            <a class="footer-mail" href="mailto:@Site.Email">@Site.Email</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
