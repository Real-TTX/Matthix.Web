@inject SiteContent Site
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? Site.BrandName)</title>
    <meta name="description" content="@Site.BrandName – @Site.Tagline" />
    <meta name="theme-color" content="#edf3f2" />
    <meta property="og:title" content="@Site.BrandName" />
    <meta property="og:description" content="@Site.Tagline" />
    <meta property="og:type" content="website" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>

    <header class="masthead" id="masthead">
        <div class="wrap masthead-inner">
            <a class="brand" href="/" aria-label="@Site.BrandName Startseite">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 220 170" role="img">
                        <path d="@Site.LogoPath"></path>
                    </svg>
                </span>
                <span class="brand-text">@Site.BrandName</span>
            </a>

            <nav class="site-nav" aria-label="Hauptnavigation">
                @foreach (var item in Site.Navigation)
                {
                    <a data-nav-link href="@item.Href">@item.Label</a>
                }
            </nav>
        </div>
        <span class="scroll-progress" id="scroll-progress" aria-hidden="true"></span>
    </header>

    <main id="main" tabindex="-1">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="divider" data-divider></div>
        <div class="wrap footer-row">
            <span class="footer-brand">
                <span class="footer-mark" aria-hidden="true">
                    <svg viewBox="0 0 220 170" role="img"><path d="@Site.LogoPath"></path></svg>
                </span>
                <span class="footer-word">@Site.BrandName</span>
            </span>
            <span class="footer-meta">@Site.Location @Site.Coordinates · MMXXVI</span>
            <a class="footer-mail" href="mailto:@Site.Email">@Site.Email</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
