@page
@model IndexModel
@{
    ViewData["Title"] = Model.Site.BrandName;
    var site = Model.Site;
}

<section class="hero" id="home" data-rail="§ 00 — START">
    <div class="wrap hero-grid">
        <span class="index-numeral hero-numeral" aria-hidden="true">00</span>

        <div class="hero-head">
            <p class="kicker">§ 00 — MATTHIX</p>
            <h1 class="hero-title">
                @foreach (var word in site.Tagline.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                {
                    <span class="hl-line">@word</span>
                }
            </h1>
        </div>

        <p class="hero-lead">@site.HeroLead</p>

        <dl class="readout">
            <div class="readout-row"><dt>Rolle</dt><span class="leader" aria-hidden="true"></span><dd>@site.Role</dd></div>
            <div class="readout-row"><dt>Standort</dt><span class="leader" aria-hidden="true"></span><dd>@site.Location · @site.Coordinates</dd></div>
            <div class="readout-row"><dt>Stack</dt><span class="leader" aria-hidden="true"></span><dd>Proxmox · UniFi · Hyper-V · MSSQL</dd></div>
            <div class="readout-row"><dt>Status</dt><span class="leader" aria-hidden="true"></span><dd><span class="pip" aria-hidden="true"></span>@site.Availability</dd></div>
        </dl>

        <div class="hero-actions">
            <a class="btn btn-solid" href="#kontakt">Kontakt aufnehmen</a>
            <a class="btn btn-line" href="#leistung">Leistungen ansehen</a>
        </div>
    </div>
    <span class="scroll-hint" aria-hidden="true">SCROLL ↓</span>
</section>

<section class="section" id="leistung" data-rail="§ 01 — LEISTUNG">
    <div class="wrap">
        <div class="section-head">
            <p class="kicker">§ 01 — Leistung</p>
            <h2 class="section-title">Klare technische Grundlagen. Saubere Umsetzung.</h2>
            <p class="section-intro">@site.ServicesIntro</p>
        </div>

        <div class="rows" role="list">
            @foreach (var service in site.Services)
            {
                <article class="row" role="listitem">
                    <span class="index-numeral row-numeral" aria-hidden="true">@service.Number</span>
                    <h3 class="row-title">@service.Title</h3>
                    <p class="row-desc">@service.Description</p>
                </article>
            }
        </div>

        <div class="stack-index" aria-label="Technologie-Stack">
            @foreach (var tech in site.Stack)
            {
                <span>@tech</span>
            }
        </div>
    </div>
</section>

<figure class="plate" aria-labelledby="plate-caption">
    <img class="plate-img"
         src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=70"
         alt="" aria-hidden="true" loading="lazy" decoding="async">
    <span class="plate-tick tl" aria-hidden="true"></span>
    <span class="plate-tick tr" aria-hidden="true"></span>
    <span class="plate-tick bl" aria-hidden="true"></span>
    <span class="plate-tick br" aria-hidden="true"></span>
    <figcaption class="plate-caption" id="plate-caption">
        <span class="plate-tag">ABB. 01 — INFRASTRUKTUR / 2026</span>
        <span class="plate-quote">Plattformen, Datenmodelle und Software werden gemeinsam gedacht — vom Rechenzentrum bis zur Oberfläche.</span>
    </figcaption>
</figure>

<section class="section" id="projekte" data-rail="§ 02 — PROJEKTE">
    <div class="wrap">
        <div class="section-head">
            <p class="kicker">§ 02 — Projekte</p>
            <h2 class="section-title">Register eigener Produkte.</h2>
            <p class="section-intro">@site.ProjectsIntro</p>
        </div>

        <div class="ledger">
            <div class="ledger-head" aria-hidden="true">
                <span>Reg</span>
                <span>Produkt</span>
                <span>Status</span>
                <span>Stack</span>
                <span>Links</span>
            </div>
            @{ var regNo = 0; }
            @foreach (var project in site.Projects)
            {
                regNo++;
                <article class="ledger-row">
                    <span class="index-numeral ledger-reg" aria-hidden="true">@($"{regNo:00}")</span>
                    <div class="ledger-product">
                        <h3>@project.Name</h3>
                        <span class="ledger-tagline">@project.Tagline</span>
                        <p class="ledger-desc">@project.Description</p>
                    </div>
                    <div class="ledger-status">
                        <span class="pip" aria-hidden="true"></span>ONLINE
                    </div>
                    <div class="ledger-stack">
                        @string.Join(" / ", project.Tags)
                    </div>
                    <div class="ledger-links">
                        @if (project.Website is not null)
                        {
                            <a href="@project.Website" target="_blank" rel="noopener noreferrer">Website<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"></path></svg></a>
                        }
                        @if (project.Repo is not null)
                        {
                            <a href="@project.Repo" target="_blank" rel="noopener noreferrer">Code<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"></path></svg></a>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="section" id="referenzen" data-rail="§ 03 — REFERENZEN">
    <div class="wrap">
        <div class="section-head">
            <p class="kicker">§ 03 — Referenzen</p>
            <h2 class="section-title">Ausgewählte Kundenprojekte.</h2>
        </div>

        <div class="rows rows-ref" role="list">
            @foreach (var reference in site.References)
            {
                <article class="row row-ref" role="listitem">
                    <span class="ref-client">@reference.Client</span>
                    <div class="row-ref-body">
                        <h3 class="row-title">@reference.Title</h3>
                        <p class="row-desc">@reference.Description</p>
                        <div class="ref-tags">@string.Join(" / ", reference.Tags)</div>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="section contact" id="kontakt" data-rail="§ 04 — KONTAKT">
    <div class="wrap">
        <div class="section-head">
            <p class="kicker">§ 04 — Kontakt</p>
            <h2 class="section-title">@site.ContactHeadline</h2>
            <p class="section-intro">@site.ContactBody</p>
        </div>
        <a class="contact-email" href="mailto:@site.Email">@site.Email</a>
    </div>
</section>
