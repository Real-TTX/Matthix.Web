@page
@model IndexModel
@{
    ViewData["Title"] = Model.Site.BrandName;
    var site = Model.Site;
}

<section class="hero" id="home">
    <div class="wrap hero-grid">
        <div class="hero-copy">
            <p class="kicker">Portfolio</p>
            <h1 class="hero-title">
                <span class="vh">@site.BrandName. </span>
                @foreach (var word in site.Tagline.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                {
                    <span class="hl-line">@word</span>
                }
            </h1>
            <p class="hero-lead">@site.HeroLead</p>
            <p class="hero-meta">
                <span>@site.Role</span>
                <span class="dot" aria-hidden="true">·</span>
                <span>@site.Location @site.Coordinates</span>
                <span class="dot" aria-hidden="true">·</span>
                <span class="avail"><span class="pip" aria-hidden="true"></span>@site.Availability</span>
            </p>
            <div class="hero-actions">
                <a class="btn btn-solid" href="#kontakt">Kontakt aufnehmen</a>
                <a class="btn btn-line" href="#leistung">Leistungen ansehen</a>
            </div>
        </div>

        <div class="hero-mark" aria-hidden="true">
            <svg class="signature" viewBox="0 0 220 170" preserveAspectRatio="xMidYMid meet">
                <path class="sig-ghost" d="@site.LogoPath"></path>
                <g class="sig-ink-group">
                    <path class="sig-ink" pathLength="1" d="@site.LogoPath"></path>
                    <path class="sig-glint" pathLength="1" d="@site.LogoPath"></path>
                </g>
            </svg>
        </div>
    </div>
    <span class="scroll-hint" aria-hidden="true">Scroll ↓</span>
</section>

<div class="divider" data-divider></div>

<section class="section" id="leistung">
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow"><span class="eyebrow-num">01</span> Leistung</p>
            <h2 class="section-title">Klare technische Grundlagen. Saubere Umsetzung.</h2>
            <p class="section-intro">@site.ServicesIntro</p>
        </div>

        <div class="svc-grid">
            @foreach (var service in site.Services)
            {
                <article class="svc">
                    <span class="svc-num" aria-hidden="true">@service.Number</span>
                    <h3 class="svc-title">@service.Title</h3>
                    <p class="svc-desc">@service.Description</p>
                </article>
            }
        </div>

        <ul class="chips" aria-label="Technologie-Stack">
            @foreach (var tech in site.Stack)
            {
                <li>@tech</li>
            }
        </ul>
    </div>
</section>

<figure class="plate" aria-labelledby="plate-caption">
    <img class="plate-img"
         src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=70"
         alt="" aria-hidden="true" loading="lazy" decoding="async">
    <figcaption class="plate-caption" id="plate-caption">
        <span class="plate-caption-text">Plattformen, Datenmodelle und Software — gemeinsam gedacht, vom Rechenzentrum bis zur Oberfläche.</span>
    </figcaption>
</figure>

<div class="divider" data-divider></div>

<section class="section" id="projekte">
    <span class="watermark" aria-hidden="true">
        <svg viewBox="0 0 220 170" preserveAspectRatio="xMidYMid meet"><path d="@site.LogoPath"></path></svg>
    </span>
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow"><span class="eyebrow-num">02</span> Projekte</p>
            <h2 class="section-title">Eigene Produkte.</h2>
            <p class="section-intro">@site.ProjectsIntro</p>
        </div>

        <div class="proj-list">
            @foreach (var project in site.Projects)
            {
                <article class="proj">
                    <div class="proj-headline">
                        <h3 class="proj-name">@project.Name</h3>
                        <span class="proj-tagline">@project.Tagline</span>
                    </div>
                    <p class="proj-desc">@project.Description</p>
                    <div class="proj-foot">
                        <span class="proj-tags">@string.Join(" · ", project.Tags)</span>
                        <span class="proj-links">
                            @if (project.Website is not null)
                            {
                                <a href="@project.Website" target="_blank" rel="noopener noreferrer">Website<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"></path></svg></a>
                            }
                            @if (project.Repo is not null)
                            {
                                <a href="@project.Repo" target="_blank" rel="noopener noreferrer">Code<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"></path></svg></a>
                            }
                        </span>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<div class="divider" data-divider></div>

<section class="section" id="referenzen">
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow"><span class="eyebrow-num">03</span> Referenzen</p>
            <h2 class="section-title">Ausgewählte Kundenprojekte.</h2>
        </div>

        <div class="ref-grid">
            @foreach (var reference in site.References)
            {
                <article class="ref">
                    <span class="ref-client">@reference.Client</span>
                    <h3 class="ref-title">@reference.Title</h3>
                    <p class="ref-desc">@reference.Description</p>
                    <span class="ref-tags">@string.Join(" · ", reference.Tags)</span>
                </article>
            }
        </div>
    </div>
</section>

<div class="divider" data-divider></div>

<section class="section contact" id="kontakt">
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow"><span class="eyebrow-num">04</span> Kontakt</p>
            <h2 class="section-title">@site.ContactHeadline</h2>
            <p class="section-intro">@site.ContactBody</p>
        </div>
        <p class="contact-line">
            Schreib mir:
            <a class="contact-email" href="mailto:@site.Email">@site.Email</a>
        </p>
    </div>
</section>
